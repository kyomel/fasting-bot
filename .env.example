APP_NAME=fasting-bot
APP_ENV=development
HTTP_ADDR=:3000
SQLITE_DSN=file:fasting.db?_busy_timeout=5000&_journal_mode=WAL&_foreign_keys=on
BOT_TICK_INTERVAL=1m
SHUTDOWN_TIMEOUT=10s

# WhatsApp Bot Configuration
# BOT_NUMBER=+62xxxxxxxxxx
# ADMIN_NUMBER=+62xxxxxxxxxx
# GROUP_NAME=Fasting Group

# Database & Session Paths
# DATABASE_PATH=fasting-bot.db
# SESSION_PATH=whatsapp-session.db

# QR Code (optional — only set for production server access)
# QR_CODE_PATH=/opt/fasting-bot/data/qr-code.png
# QR_CODE_HOST=root@your-server-ip
