# --- WhatsApp Bot (REQUIRED) ---
# Isi dengan nomor bot & admin masing-masing. ALLOWED_GROUP_JID dipakai
# untuk membatasi command grup ke satu grup WhatsApp yang dipercaya.
BOT_NUMBER=
ADMIN_NUMBER=
ALLOWED_GROUP_JID=
GROUP_NAME=Fasting Group

# --- Database & Session ---
DATABASE_PATH=/opt/fasting-bot/data/fasting-bot.db
SESSION_PATH=/opt/fasting-bot/data/whatsapp-session.db
BACKUP_RETENTION_DAYS=14

# --- Timezone ---
# Gunakan IANA timezone agar parsing jadwal akurat.
APP_TIMEZONE=Asia/Jakarta

# --- QR Code (production VPS only) ---
QR_CODE_PATH=
QR_CODE_HOST=
